FUNCTION damerau_levenshtein(a, b):
    if a == b: return 0
    if a is empty: return length(b)
    if b is empty: return length(a)

    la = length(a)
    lb = length(b)

    // last_row[c] = last row index where character c appeared in `a`
    last_row = empty map (char → int)

    // d is a (la+2) × (lb+2) matrix
    d = matrix of size (la+2) × (lb+2)

    max_dist = la + lb
    d[0][0]  = max_dist

    FOR i FROM 0 TO la:
        d[i+1][0] = max_dist
        d[i+1][1] = i

    FOR j FROM 0 TO lb:
        d[0][j+1] = max_dist
        d[1][j+1] = j

    FOR i FROM 1 TO la:
        last_col = 0   // last col in `b` where a[i] matched

        FOR j FROM 1 TO lb:
            i1 = last_row[b[j]], defaulting to 0
            j1 = last_col
            cost = 0 if a[i] == b[j] else 1

            if cost == 0: last_col = j

            d[i+1][j+1] = MIN(
                d[i  ][j  ] + cost,            // substitute (or match)
                d[i+1][j  ] + 1,               // insert
                d[i  ][j+1] + 1,               // delete
                d[i1 ][j1 ] + (i - i1 - 1)    // transpose +
                             + 1               //   gap in a
                             + (j - j1 - 1)   //   gap in b
            )

        last_row[a[i]] = i

    RETURN d[la+1][lb+1]


---


FUNCTION suggest(token, keywords):
    CONSTANT MAX_DIST = 2

    if token in keywords:   return null
    if length(token) < 2:   return null

    best_match = null
    best_dist  = MAX_DIST + 1

    FOR EACH keyword IN keywords:

        // Fast prune: length gap alone exceeds budget
        if |length(token) - length(keyword)| > MAX_DIST:
            continue

        dist = damerau_levenshtein(token, keyword)

        if dist < best_dist:
            best_dist  = dist
            best_match = keyword

    RETURN best_match   // null if nothing was close enough


---


// Caller
token      = <identifier that failed to parse>
suggestion = suggest(token, LANGUAGE_KEYWORDS)

IF suggestion is not null:
    error("unknown keyword '" + token + "'. Did you mean '" + suggestion + "'?")
ELSE:
    error("unknown keyword '" + token + "'.")
